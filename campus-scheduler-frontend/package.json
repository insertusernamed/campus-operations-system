{
	"name": "campus-operations-system-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"test:e2e": "playwright test",
		"a11y:discover": "tsx scripts/a11y/discover-routes.ts",
		"a11y:runtime": "tsx scripts/a11y/runtime.ts",
		"a11y:lint": "tsx scripts/a11y/lint.ts",
		"a11y:report": "tsx scripts/a11y/report.ts",
		"a11y:scan": "tsx scripts/a11y/scan.ts",
		"a11y:scan:fast": "tsx scripts/a11y/scan.ts --scenario=normal --workers=4 --fully-parallel --strict-mock-gaps --strict-runtime-errors",
		"a11y:scan:deep": "tsx scripts/a11y/scan.ts --scenario=empty,normal,dense,error --workers=6 --fully-parallel --strict-mock-gaps --strict-runtime-errors --strict-uncovered-routes"
	},
	"dependencies": {
		"@schedule-x/calendar": "^4.1.0",
		"@schedule-x/events-service": "^4.1.0",
		"@schedule-x/theme-default": "^4.1.0",
		"@schedule-x/vue": "^4.0.0",
		"@stomp/stompjs": "^7.2.1",
		"@tailwindcss/vite": "^4.1.18",
		"axios": "^1.13.2",
		"floating-vue": "^5.2.2",
		"ical-generator": "^10.0.0",
		"sockjs-client": "^1.6.1",
		"tailwindcss": "^4.1.18",
		"temporal-polyfill": "0.3.0",
		"vue": "^3.5.24",
		"vue-router": "^4.6.4",
		"vue3-toastify": "^0.2.8"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@playwright/test": "^1.57.0",
		"@types/node": "^24.10.1",
		"@types/sockjs-client": "^1.5.4",
		"@typescript-eslint/parser": "^8.56.0",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vue/tsconfig": "^0.8.1",
		"eslint": "^10.0.0",
		"eslint-plugin-vue": "^10.8.0",
		"eslint-plugin-vuejs-accessibility": "^2.5.0",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"vite": "npm:rolldown-vite@7.2.5",
		"vue-eslint-parser": "^10.4.0",
		"vue-tsc": "^3.1.4"
	},
	"overrides": {
		"vite": "npm:rolldown-vite@7.2.5"
	}
}
